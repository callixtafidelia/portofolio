# ─────────────────────────────────────────────────────────────────────────
# Deployment: Vercel (server runtime). Copy this file to .env.local for local
# dev, and add the same vars in Vercel → Project → Settings → Environment
# Variables for production. Never commit real secrets (.env* is gitignored).
# ─────────────────────────────────────────────────────────────────────────

# ── Keystatic — GitHub storage mode ──────────────────────────────────────
# Create a Keystatic GitHub App (see the checklist), then set these.
# The app slug is the last path segment of your app's GitHub URL.
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=

# ── Upstash Redis — shared photo upvotes ─────────────────────────────────
# Create a free Upstash Redis database, then copy its REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Resume passcode gate ──────────────────────────────────────────────────
# Shared passcode visitors enter to download the resume (casual friction
# gate, not real auth). The PDF itself lives in Vercel Blob, not the repo —
# the API route always serves whatever was uploaded most recently under the
# "private/resume*" prefix, so swapping resumes is just an upload, no env
# var to update.
RESUME_PASSCODE=

# Read/write token for your Blob store (Vercel → Storage → Blob → your
# store → tokens). If the store is connected to this project in Vercel,
# this is usually already set for you automatically — only add it here for
# local dev, or to run scripts/upload-resume-to-blob.mjs.
BLOB_READ_WRITE_TOKEN=
